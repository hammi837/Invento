# Django
SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database — PostgreSQL
DB_NAME=inventory_db
DB_USER=postgres
DB_PASSWORD=yourpassword
DB_HOST=localhost
DB_PORT=5432

# Set to true to use SQLite locally (no PostgreSQL needed)
USE_SQLITE=false

# CORS — your React frontend origin
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Sentry (production only — leave blank in development)
SENTRY_DSN=
